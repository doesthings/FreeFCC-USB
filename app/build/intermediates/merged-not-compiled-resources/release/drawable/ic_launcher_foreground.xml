<?xml version="1.0" encoding="utf-8"?>
<!-- Launcher glyph: a stylised radio-wave / FCC broadcast icon.
     Drawn as concentric arcs emanating from a central dot — the universal
     "signal" pictogram. Cyan on transparent, large enough for adaptive
     masking at 108dp. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Center dot -->
    <path
        android:fillColor="#4FC3F7"
        android:pathData="M54,54m-4,0a4,4 0 1,0 8,0a4,4 0 1,0 -8,0" />
    <!-- Inner arc -->
    <path
        android:strokeColor="#4FC3F7"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M44,44A14,14 0 1,1 64,44" />
    <!-- Middle arc -->
    <path
        android:strokeColor="#4FC3F7"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M36,36A26,26 0 1,1 72,36" />
    <!-- Outer arc -->
    <path
        android:strokeColor="#4FC3F7"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillAlpha="0.5"
        android:pathData="M28,28A38,38 0 1,1 80,28" />
</vector>